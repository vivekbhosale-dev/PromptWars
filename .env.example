# MonsoonGuard — Environment Variables
# Copy this file as .env and fill in your API keys
# These are used by Vercel serverless functions (api/ folder)

# Google Gemini API Key — get free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenWeatherMap API Key — get free at https://home.openweathermap.org/api_keys
WEATHER_API_KEY=
